# UAT: https://uatidentityserver.joblogic.com | Prod: provided by Joblogic
JOBLOGIC_IDENTITY_URL="https://uatidentityserver.joblogic.com"
JOBLOGIC_CLIENT_ID=""
JOBLOGIC_CLIENT_SECRET=""
JOBLOGIC_TENANT_ID=""

# Reporting
REPORT_EMAIL_TO=""
REPORT_EMAIL_FROM=""

# Cron Secret (for daily report generation endpoint)
CRON_SECRET=""
