# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# SSO Provider (OpenID Connect)
# Configure with your identity provider (Azure AD, Okta, Auth0, etc.)
SSO_CLIENT_ID=""
