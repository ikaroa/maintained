generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("technician")
  accounts      Account[]
  sessions      Session[]
  interactions  VoiceInteraction[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VoiceInteraction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  query         String
  queryType     String
  response      String
  duration      Int      // milliseconds
  success       Boolean
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([queryType])
}

model DailyReport {
  id                String   @id @default(cuid())
  date              DateTime @unique
  totalQueries      Int
  uniqueUsers       Int
  avgResponseTime   Int      // milliseconds
  errorCount        Int
  topQueryTypes     String   // JSON string
  peakHour          Int
  generatedAt       DateTime @default(now())
}
